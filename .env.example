# ==============================================================================
# TEMPLATE DE CONFIGURAÇÃO — copie para .env e preencha
# ==============================================================================
# Em produção: NUNCA versionar o .env. SECRET_KEY deve ser única por ambiente.
# Gere uma SECRET_KEY com:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ==============================================================================

# Caminhos de arquivos
ARQUIVO_PRECIFICACAO=Precificacao.xlsx
ARQUIVO_DESCRICAO=DESCRIÇÃO.xlsx
ARQUIVO_REMOVER=termos_remover.txt
ARQUIVO_SUBSTITUIR=termos_substituir.txt

# URL base de imagens
URL_BASE_IMAGENS=https://topshop-tiny.com.br/wp-content/uploads/tiny

# OneDrive (até 5 caminhos)
ONEDRIVE_PRECIFICACAO_1=OneDrive - Top Shop\Criação de Anúncios - Documentos\Precificacao Amazon.xlsx
ONEDRIVE_PRECIFICACAO_2=OneDrive\Criação de Anúncios - Documentos\Precificacao Amazon.xlsx
ONEDRIVE_PRECIFICACAO_3=
ONEDRIVE_PRECIFICACAO_4=
ONEDRIVE_PRECIFICACAO_5=

# AUTH — OBRIGATÓRIO em produção
SECRET_KEY=GERE_UMA_NOVA_COM_secrets.token_hex_32
DATABASE_URL=sqlite:///auth.db
SESSION_COOKIE_SECURE=0   # 1 em produção (atrás de HTTPS)
ENV=development           # production em produção

# ============================================================
# SHAREPOINT — Sincronização automática da Precificação
# ============================================================
# Configure uma App Registration no Azure AD com permissão
# Sites.Selected (recomendado) ou Sites.Read.All. Para Sites.Selected,
# o admin do tenant precisa autorizar a App neste site específico
# via PowerShell ou Graph Explorer:
#
#   POST https://graph.microsoft.com/v1.0/sites/{site-id}/permissions
#   { "roles": ["read"], "grantedToIdentities": [
#       { "application": { "id": "{app-id}", "displayName": "App Name" } }
#   ] }
#
# Caminhos do site e arquivo são editáveis no painel admin
# (Configurações → SharePoint).
# ============================================================
SHAREPOINT_TENANT_ID=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=
